font-family = MonoLisa Cursive
# font-family = Comic Code Ligatures Medium
font-size = 14
adjust-cell-height = 10%
theme = dark:catppuccin-mocha.conf, light:catppuccin-latte.conf
mouse-hide-while-typing = true
window-padding-balance = true
window-padding-x = 8
window-padding-y = 8
# macos-titlebar-style = hidden
macos-titlebar-style = tabs
macos-non-native-fullscreen = false
# Options: `official` (default), `blueprint`, `chalkboard`, `microchip`, `glass`, `holographic`, `paper`, `retro`, `xray`, `custom-style`
macos-icon = xray
macos-option-as-alt = true
window-colorspace = display-p3
window-save-state = always
confirm-close-surface = false
quit-after-last-window-closed = true
auto-update = check
# mouse-scroll-multiplier = discrete:0.75
copy-on-select = clipboard
notify-on-command-finish = unfocused
notify-on-command-finish-action = bell, notify
window-inherit-working-directory = false
tab-inherit-working-directory = true
split-inherit-working-directory = true
# fixes `Error opening terminal: xterm-ghostty` on remote hosts.
# `ssh-terminfo` auto-installs Ghostty's terminfo on connect (cached per host).
# `ssh-env` falls back to xterm-256color + COLORTERM/TERM_PROGRAM if that fails.
# Omitted features keep their defaults (e.g. keep cursor, title, and path enabled).
shell-integration-features = ssh-env, ssh-terminfo
keybind = shift+enter=text:\n
# Linux/GTK-only overrides. Silently skipped on macOS but loaded on Linux
config-file = ?linux.conf

# NOTE: use the CLI to search for configs (and their defaults and docs):
# E.g. `ghostty +show-config --default --docs | rg ^macos-icon -B35`