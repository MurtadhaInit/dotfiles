{
  "lsp": {
    "golangci-lint": {
      "initialization_options": {
        "command": [
          "golangci-lint",
          "run",
          "--output.json.path",
          "stdout",
          "--show-stats=false",
          "--output.text.path=",
        ],
      },
    },
    "mdx-analyzer": {
      "initialization_options": {
        "typescript": {
          "enabled": true,
        },
      },
    },
  },
  "languages": {
    "Go": {
      "language_servers": ["gopls", "golangci-lint"],
    },
  },
  "file_types": {
    "Ansible": [
      "**.ansible.yml",
      "**.ansible.yaml",
      "**/defaults/*.yml",
      "**/defaults/*.yaml",
      "**/meta/*.yml",
      "**/meta/*.yaml",
      "**/tasks/*.yml",
      "**/tasks/*.yaml",
      "**/handlers/*.yml",
      "**/handlers/*.yaml",
      "**/group_vars/*.yml",
      "**/group_vars/*.yaml",
      "**/playbooks/*.yaml",
      "**/playbooks/*.yml",
      "**playbook*.yaml",
      "**playbook*.yml",
    ],
    "GitHub Actions": [".github/workflows/*.yml", ".github/workflows/*.yaml"],
  },
  "semantic_tokens": "combined",
  "cli_default_open_behavior": "new_window",
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
  },
  "project_panel": {
    "dock": "right",
  },
  "outline_panel": {
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "colorize_brackets": true,
  "sticky_scroll": {
    "enabled": true,
  },
  "on_last_window_closed": "quit_app",
  "git_panel": {
    "dock": "right",
    "tree_view": true,
  },
  "agent": {
    "dock": "left",
    "inline_assistant_model": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-5-thinking-latest",
    },
    "default_profile": "minimal",
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "anthropic",
      "model": "claude-opus-4-7-latest",
    },
  },
  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha",
  },
  "vim_mode": true,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "base_keymap": "VSCode",
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha",
  },
  "buffer_font_family": "MonoLisa Cursive",
  "buffer_font_fallbacks": ["Symbols Nerd Font Mono"],
  "buffer_font_size": 14,
  "terminal": {
    "font_family": "Comic Code Ligatures",
    "font_fallbacks": ["Symbols Nerd Font Mono"],
    "line_height": "standard",
    "font_size": 14,
  },
}
